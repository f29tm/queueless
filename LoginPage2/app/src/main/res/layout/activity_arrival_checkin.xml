<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".ArrivalCheckInActivity">

    <!-- Bottom Navigation Bar -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        app:itemTextColor="@color/black"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu"
        app:elevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 2. Scrollable Main Content Area -->
    <!-- This ScrollView now replaces the outer padding and contains all your existing UI elements. -->
    <!-- It is constrained to be between the top of the parent and the top of the BottomNavigationView. -->
    <ScrollView
        android:id="@+id/mainContentScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/bottom_navigation_bar"
        android:padding="16dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Welcome Text -->
            <TextView
                android:id="@+id/welcomeTextView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Welcome, Latifa!"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#374151"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Appointment Detail Text -->
            <TextView
                android:id="@+id/appointmentDetailTextView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Your next appointment details:"
                android:textSize="16sp"
                android:textColor="#6B7280"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@+id/welcomeTextView"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Appointment Details Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/appointmentCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:layout_constraintTop_toBottomOf="@+id/appointmentDetailTextView"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/doctorNameTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dr. Meriem Bettayeb (Cardiology)"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#1F2937" />

                    <TextView
                        android:id="@+id/timeLocationTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Today at 10:30 AM | Clinic 3, 2nd Floor"
                        android:textSize="14sp"
                        android:textColor="#4B5563"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Check-In Button -->
            <Button
                android:id="@+id/arrivalCheckInButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="I HAVE ARRIVED - Check In"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:paddingVertical="12dp"
                android:layout_marginTop="32dp"
                android:backgroundTint="#10B981"
                app:layout_constraintTop_toBottomOf="@+id/appointmentCard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Queue Status Card (Initially Hidden) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/queueStatusCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@+id/arrivalCheckInButton"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginBottom="24dp">
                <!-- Added constraint to bottom to ensure ScrollView wraps content fully -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="#D1FAE5"> <!-- Light Green Background -->

                    <TextView
                        android:id="@+id/statusTitleTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CHECK-IN SUCCESSFUL"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#059669" />

                    <TextView
                        android:id="@+id/queuePositionTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="You are currently: 3rd in line."
                        android:textSize="16sp"
                        android:textColor="#10B981"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:id="@+id/pathwayTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pathway: Proceed directly to Clinic 3, 2nd Floor."
                        android:textSize="16sp"
                        android:textColor="#10B981"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>