<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- Title -->
        <TextView
            android:id="@+id/tvWelcomeVisitor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome Visitor!"
            android:textStyle="bold"
            android:textSize="28sp"
            android:textColor="#2E7D32"
            android:paddingTop="40dp" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tvVisitorSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Here is a preview of the QueueLess App"
            android:textSize="16sp"
            android:textColor="#555555"
            android:layout_marginTop="8dp" />

        <!-- Preview Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@drawable/rounded_preview_card"
            android:padding="20dp"
            android:layout_marginTop="40dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="(Preview Content Here)"
                android:textColor="#777777"
                android:textSize="18sp" />
        </LinearLayout>

    </LinearLayout>

</ScrollView>
