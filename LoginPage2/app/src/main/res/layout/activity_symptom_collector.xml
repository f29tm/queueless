<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".SymptomCollectorActivity">

    <!-- Bottom Navigation Bar -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        app:itemTextColor="@color/black"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu"
        app:elevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scrollable Main Content Area -->
    <!-- This ScrollView contains all symptom input and is constrained to the top of the screen and the top of the BottomNavigationView. -->
    <ScrollView
        android:id="@+id/mainContentScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/bottom_navigation_bar"
        android:padding="16dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Title Header -->
            <TextView
                android:id="@+id/titleTextView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Symptom Check-In"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#374151"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Instruction Text -->
            <TextView
                android:id="@+id/instructionTextView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="1. Select any symptoms that apply below."
                android:textSize="14sp"
                android:textColor="#6B7280"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@+id/titleTextView"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Symptom Checkbox List (MCQ Section) -->
            <ScrollView
                android:id="@+id/symptomMcqScroll"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/rounded_edittext_bg"
                android:padding="8dp"
                app:layout_constraintTop_toBottomOf="@+id/instructionTextView"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:id="@+id/mcqContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Checkboxes for common critical symptoms -->
                    <CheckBox android:id="@+id/cb_chest_pain" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Severe Chest Pain" android:textColor="#1F2937" android:paddingVertical="4dp" />
                    <CheckBox android:id="@+id/cb_shortness_breath" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Shortness of Breath / Difficulty Breathing" android:textColor="#1F2937" android:paddingVertical="4dp" />
                    <CheckBox android:id="@+id/cb_severe_bleeding" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Uncontrolled / Severe Bleeding" android:textColor="#1F2937" android:paddingVertical="4dp" />
                    <CheckBox android:id="@+id/cb_loss_consciousness" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Loss of Consciousness / Fainting" android:textColor="#1F2937" android:paddingVertical="4dp" />
                    <CheckBox android:id="@+id/cb_high_fever" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="High Fever (above 39°C / 102.2°F)" android:textColor="#1F2937" android:paddingVertical="4dp" />
                    <CheckBox android:id="@+id/cb_fracture" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Suspected Fracture / Dislocation" android:textColor="#1F2937" android:paddingVertical="4dp" />
                    <CheckBox android:id="@+id/cb_persistent_vomiting" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Persistent Vomiting or Diarrhea" android:textColor="#1F2937" android:paddingVertical="4dp" />
                </LinearLayout>
            </ScrollView>

            <!-- Instruction Text for Text Input -->
            <TextView
                android:id="@+id/instructionTextDetailed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="2. Describe any other symptoms in detail below."
                android:textSize="14sp"
                android:textColor="#6B7280"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@+id/symptomMcqScroll"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Symptom Input Field (Typing Section) -->
            <EditText
                android:id="@+id/symptomInputEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minHeight="80dp"
                android:gravity="top|start"
                android:hint="Enter additional symptoms here (e.g., 'headache')..."
                android:inputType="textMultiLine"
                android:padding="12dp"
                android:textSize="16sp"
                android:textColor="#1F2937"
                android:background="@drawable/rounded_edittext_bg"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@+id/instructionTextDetailed"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Triage Button -->
            <Button
                android:id="@+id/triageButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Determine Urgency"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:paddingVertical="12dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="#EF4444"
                app:layout_constraintTop_toBottomOf="@+id/symptomInputEditText"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Result Display Area -->
            <TextView
                android:id="@+id/resultTextView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:textSize="18sp"
                android:textStyle="bold"
                android:padding="16dp"
                android:visibility="gone"
                android:textColor="#1F2937"
                android:background="@drawable/rounded_result_bg"
                app:layout_constraintTop_toBottomOf="@+id/triageButton"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginBottom="24dp"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>